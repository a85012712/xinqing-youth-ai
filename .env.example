# Alternative Providers:
# DeepSeek: https://api.deepseek.com/v1
# Moonshot: https://api.moonshot.cn/v1
# ZhipuAI: https://api.zhipuai.cn/v1
# Xiaomi MiMo: https://api.xiaomimimo.com/v1

# Model Parameters
MAX_TOKENS=8192
TEMPERATURE=0.7
